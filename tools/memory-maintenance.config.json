{
  "retentionDays": 90,
  "archiveRoot": "memory/archive",
  "summariesRoot": "memory/summaries",
  "maintenanceRoot": "memory/maintenance",
  "graph": {
    "enabled": true,
    "root": "memory/graph",
    "versionPath": "memory/pam.version.json",
    "catalogPath": "memory/graph/catalog.json"
  },
  "synthesis": {
    "enabled": false,
    "provider": "none",
    "command": "",
    "args": [],
    "stdin": "none",
    "examples": {
      "codex": {
        "provider": "codex",
        "command": "codex",
        "args": [
          "exec",
          "--skip-git-repo-check",
          "--full-auto",
          "--ephemeral",
          "-C",
          "{workspace}",
          "-o",
          "{output}",
          "{prompt}"
        ]
      },
      "claude": {
        "provider": "claude",
        "command": "claude",
        "args": [
          "-p",
          "{prompt}"
        ]
      },
      "ollama": {
        "provider": "ollama",
        "command": "ollama",
        "args": [
          "run",
          "llama3.1"
        ],
        "stdin": "prompt"
      }
    }
  },
  "workspace": {
    "name": "Example Memory Workspace",
    "description": "Markdown-based memory workspace maintained by an AI agent.",
    "indexPath": "memory/index.md",
    "runtimePath": "memory/agent-memory/pam-runtime.md",
    "llmWikiPath": "memory/agent-memory/llm-wiki.md",
    "policyPaths": [
      "AGENTS.md",
      "CLAUDE.md",
      "memory/agent-memory/pam.md"
    ]
  },
  "managedLogs": [
    {
      "source": "memory/conversation-log.md",
      "archiveKey": "conversation-log",
      "activeEntryLimit": 80
    },
    {
      "source": "memory/knowledge-log.md",
      "archiveKey": "knowledge-log",
      "activeEntryLimit": 120
    }
  ],
  "readContextPaths": [
    "AGENTS.md",
    "CLAUDE.md",
    "README.md",
    "memory/index.md",
    "memory/pam.version.json",
    "memory/graph",
    "memory/agent-memory/pam-runtime.md",
    "memory/conversation-log.md",
    "memory/knowledge-log.md"
  ],
  "protectedPaths": [
    "AGENTS.md",
    "CLAUDE.md",
    "memory/agent-memory",
    "memory/sources"
  ]
}
